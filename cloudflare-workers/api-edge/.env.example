# Trusted host origin for same-origin API calls. Dev trusts the request's own
# origin automatically; production fails loud without this set (a credential-
# forwarding call errors instead of silently running unauthenticated).
VENDO_BASE_URL=http://localhost:3000
# Model key — REQUIRED in production. In dev, `vendo init` can mint a free starter key instead.
# ANTHROPIC_API_KEY=
