[Unit]
Description=OpenSandbox Secrets Service (gRPC)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/bin/opensandbox-secrets
Restart=always
RestartSec=5
Environment=HOME=/root
Environment=OPENSANDBOX_SECRETS_GRPC_PORT=9095
Environment=OPENSANDBOX_SECRETS_ARN=arn:aws:secretsmanager:us-east-2:739940681129:secret:opensandbox/server-vtN2Ez
EnvironmentFile=-/etc/opensandbox/server.env
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
